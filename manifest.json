{
  "manifest_version": 3,
  "name": "Tab Stash",
  "version": "1.0",
  "description": "Stash open tabs into organized study sessions and restore them with one click.",
  "permissions": ["tabs", "storage", "tabGroups", "favicon"],
  "action": {
    "default_title": "Tab Stash",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}